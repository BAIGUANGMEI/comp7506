{
  "expo": {
    "name": "Document AI",
    "slug": "document-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "documentai",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.baiguangmei.documentai"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F8FAFC"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Document AI to choose an avatar from your photo library.",
          "cameraPermission": false,
          "microphonePermission": false
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ],
      "expo-apple-authentication"
    ]
  }
}
